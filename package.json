{
  "name": "macos-mcp-server",
  "version": "0.2.0",
  "description": "MCP server for macOS — Apple Mail, Calendar, and Reminders via Claude",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "macos-mcp-server": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test build/__tests__/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "apple-mail",
    "apple-calendar",
    "apple-reminders",
    "claude",
    "macos",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "hono": ">=4.12.7"
  }
}
